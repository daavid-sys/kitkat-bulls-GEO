{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=pjyrhjbkpxuomfvaubkk"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "REPLACE_WITH_PAT_FROM_HTTPS_SUPABASE_COM_DASHBOARD_ACCOUNT_TOKENS"
      }
    }
  }
}
